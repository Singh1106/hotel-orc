{
  "name": "hotel-orc",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/temporal/worker.ts",
    "build": "npm run build:app && npm run build:workflows",
    "build:app": "esbuild src/index.ts --bundle --platform=node --target=node24 --format=esm --outfile=dist/index.js --external:@temporalio/* --external:express --external:redis --external:axios --external:dotenv",
    "build:workflows": "esbuild src/temporal/workflows.ts --bundle --platform=node --target=node24 --format=esm --outfile=dist/workflows.js --external:@temporalio/workflow",
    "start": "node dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@temporalio/client": "^1.16.1",
    "@temporalio/worker": "^1.16.1",
    "@temporalio/workflow": "^1.16.1",
    "axios": "^1.15.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "redis": "^5.12.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2"
  }
}
